.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx 40rpx 60rpx;
  background:
    radial-gradient(circle at 18% 18%, rgba(210, 38, 48, 0.38) 0%, rgba(210, 38, 48, 0) 30%),
    radial-gradient(circle at 82% 74%, rgba(0, 119, 73, 0.36) 0%, rgba(0, 119, 73, 0) 28%),
    linear-gradient(150deg, #0b2f6b 0%, #123f86 34%, #f6f7fb 34.2%, #f6f7fb 45%, #0f7a4f 45.2%, #0d6446 68%, #c91f35 68.2%, #9f1730 100%);
  overflow: hidden;
}

.logo-stage {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 420rpx;
  height: 320rpx;
  margin-bottom: 28rpx;
}

.logo-stage::before,
.logo-stage::after {
  content: "";
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.logo-stage::before {
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.16);
  box-shadow: 0 28rpx 80rpx rgba(6, 18, 44, 0.28);
}

.logo-stage::after {
  width: 260rpx;
  height: 260rpx;
  border: 4rpx solid rgba(246, 196, 83, 0.72);
}

.logo-ring {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 6rpx solid rgba(255, 255, 255, 0.62);
  box-shadow: 0 22rpx 60rpx rgba(7, 23, 58, 0.26);
  animation: logoFloat 3.2s ease-in-out infinite;
}

.worldcup-logo {
  width: 150rpx;
  height: 150rpx;
}

@keyframes logoFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.title {
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 6rpx;
  text-shadow: 0 8rpx 24rpx rgba(7, 23, 58, 0.24);
}

.subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
  letter-spacing: 4rpx;
  margin-bottom: 40rpx;
}

.lang-buttons {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  width: 100%;
  max-width: 520rpx;
}

.lang-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  border-radius: 18rpx;
  font-size: 32rpx;
  box-shadow: 0 18rpx 42rpx rgba(7, 23, 58, 0.18);
}

.lang-btn::after {
  border: none;
}

.lang-flag {
  font-size: 38rpx;
}

.lang-label {
  font-weight: 700;
  color: #123f86;
}
