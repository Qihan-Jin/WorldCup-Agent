.container {
  padding: 16rpx 20rpx 60rpx;
  background: linear-gradient(180deg, #EEF4FF 0%, var(--bg) 300rpx);
  min-height: 100vh;
}

.calendar {
  background: var(--card);
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(18, 63, 134, 0.06);
  box-shadow: var(--shadow);
}

.cal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.cal-title {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--blue);
}

.cal-nav {
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--blue);
  background: var(--soft-blue);
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: 800;
}

.cal-weekdays {
  display: flex;
  margin-bottom: 8rpx;
}

.cal-wd {
  flex: 1;
  text-align: center;
  font-size: 22rpx;
  color: var(--text3);
  font-weight: 700;
}

.cal-grid {
  display: flex;
  flex-wrap: wrap;
}

.cal-day {
  width: calc(100% / 7);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  border-radius: 12rpx;
  position: relative;
  color: var(--text);
}

.cal-day.out {
  opacity: 0.18;
}

.cal-day.today {
  background: var(--soft-gold);
  color: var(--dark);
  font-weight: 800;
}

.cal-day.selected {
  background: var(--blue);
  color: #fff;
  font-weight: 800;
  box-shadow: 0 8rpx 18rpx rgba(18, 63, 134, 0.2);
}

.cal-day.has-match {
  font-weight: 700;
}

.cal-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--green);
  position: absolute;
  bottom: 8rpx;
}

.cal-day.selected .cal-dot {
  background: var(--gold);
}

.date-label {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--blue);
  display: block;
  margin: 0 4rpx 14rpx;
}

.loading,
.empty {
  text-align: center;
  color: var(--text3);
  padding-top: 60rpx;
  display: block;
  font-size: 26rpx;
}

.match-card {
  background: var(--card);
  border-radius: 18rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(18, 63, 134, 0.06);
  box-shadow: var(--shadow);
}
.match-card.favorite-match {
  border-color: rgba(246, 196, 83, 0.85);
  box-shadow: 0 14rpx 34rpx rgba(246, 196, 83, 0.16);
}

.match-top {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.match-stage {
  font-size: 20rpx;
  color: var(--blue);
  font-weight: 800;
}

.match-venue {
  flex: 1;
  text-align: right;
  font-size: 20rpx;
  color: var(--text3);
}

.match-vs {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  margin-bottom: 12rpx;
}

.team-name {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text);
}
.team-name.favorite-team {
  color: var(--red);
}

.vs-text {
  min-width: 64rpx;
  text-align: center;
  font-size: 24rpx;
  color: var(--text3);
  font-weight: 700;
}

.score {
  min-width: 112rpx;
  text-align: center;
  font-size: 34rpx;
  font-weight: 800;
  color: var(--red);
}

.match-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-top: 1rpx solid var(--border);
  padding-top: 10rpx;
}

.match-time {
  font-size: 24rpx;
  color: var(--blue);
  font-weight: 700;
}

.remind-action {
  font-size: 24rpx;
  color: var(--red);
  font-weight: 700;
}
