.container {
  padding: 30rpx 28rpx 160rpx;
  background: linear-gradient(180deg, #EEF4FF 0%, var(--bg) 320rpx);
  min-height: 100vh;
}

.header { margin-bottom: 28rpx; }
.title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: var(--blue);
}
.desc {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: var(--text2);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  height: 82rpx;
  padding: 0 22rpx;
  background: var(--card);
  border: 2rpx solid rgba(18, 63, 134, 0.12);
  border-radius: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}
.search-icon { font-size: 28rpx; opacity: 0.45; }
.search-input { flex: 1; height: 100%; font-size: 28rpx; }
.search-placeholder { color: var(--text3); }

.team-grid { flex: 1; }
.team-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 12rpx;
  background: var(--card);
  border: 2rpx solid var(--border);
  border-radius: 16rpx;
  position: relative;
  box-shadow: var(--shadow);
}
.team-card.selected {
  border-color: var(--green);
  background: linear-gradient(90deg, var(--soft-green), #fff);
}

.team-flag {
  width: 56rpx;
  height: 40rpx;
  border-radius: 6rpx;
  border: 1rpx solid #EEE;
  flex-shrink: 0;
}
.team-name { flex: 1; font-size: 28rpx; font-weight: 700; color: var(--text); }
.team-group { font-size: 22rpx; color: var(--text3); margin-right: 40rpx; }

.check-mark {
  position: absolute;
  right: 20rpx;
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--green);
  color: #fff;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 700;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(transparent, var(--bg) 30%);
}
.confirm-btn {
  width: 100%;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--blue), var(--green));
  color: #fff;
  border: none;
  box-shadow: 0 12rpx 30rpx rgba(18, 63, 134, 0.28);
}
.confirm-btn::after { border: none; }
