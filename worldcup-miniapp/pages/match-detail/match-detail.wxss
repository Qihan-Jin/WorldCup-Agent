.container {
  min-height: 100vh;
  padding: 0 24rpx 70rpx;
  background: var(--bg);
}

.loading {
  display: block;
  padding-top: 90rpx;
  text-align: center;
  color: var(--text3);
}

.empty-card,
.card {
  background: var(--card);
  border-radius: 18rpx;
  padding: 24rpx;
  box-shadow: var(--shadow);
}

.empty-card {
  margin-top: 40rpx;
  text-align: center;
  color: var(--text2);
}

.scoreboard {
  position: relative;
  min-height: 430rpx;
  margin: 0 -24rpx 0;
  overflow: hidden;
  color: #fff;
  background: linear-gradient(135deg, var(--blue2), var(--blue));
}

.hero-flag-bg,
.hero-shade {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-flag-bg {
  opacity: 0.72;
}

.hero-shade {
  background: linear-gradient(180deg, rgba(8, 14, 28, 0.34), rgba(8, 14, 28, 0.86));
}

.score-content {
  position: relative;
  z-index: 1;
  padding: 34rpx 28rpx 30rpx;
}

.match-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 23rpx;
  font-weight: 800;
}

.status-pill {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.18);
}

.score-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 54rpx;
}

.team-side {
  width: 230rpx;
  min-height: 190rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.team-flag {
  width: 96rpx;
  height: 68rpx;
  margin-bottom: 16rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.92);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.16);
}

.team-name {
  width: 100%;
  text-align: center;
  font-size: 31rpx;
  line-height: 1.18;
  font-weight: 900;
  white-space: normal;
}

.team-name.winner {
  color: var(--gold);
}

.favorite-tag {
  margin-top: 12rpx;
  padding: 3rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(246,196,83,0.92);
  color: #452b00;
  font-size: 19rpx;
  font-weight: 800;
}

.score-center {
  width: 190rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.score-text {
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1;
}

.score-sub {
  margin-top: 16rpx;
  color: rgba(255,255,255,0.82);
  font-size: 21rpx;
  text-align: center;
}

.score-local {
  margin-top: 6rpx;
  color: rgba(255,255,255,0.68);
  font-size: 19rpx;
  text-align: center;
}

.countdown {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: 800;
}

.tabs {
  display: flex;
  margin: 0 -24rpx 20rpx;
  padding: 0 24rpx;
  height: 86rpx;
  align-items: center;
  gap: 10rpx;
  background: var(--card);
  box-shadow: var(--shadow);
}

.tab {
  flex: 1;
  height: 62rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 31rpx;
  color: var(--text2);
  font-size: 26rpx;
  font-weight: 800;
}

.tab.active {
  color: #fff;
  background: var(--blue);
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.remind-btn,
.outline-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.remind-btn {
  color: #fff;
  background: var(--red);
}

.outline-btn {
  color: var(--blue);
  background: #fff;
  border: 2rpx solid var(--border);
}

.remind-btn::after,
.outline-btn::after {
  border: none;
}

.card {
  margin-bottom: 20rpx;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.card-title {
  display: block;
  margin-bottom: 16rpx;
  color: var(--blue);
  font-size: 30rpx;
  font-weight: 900;
}

.card-head .card-title {
  margin-bottom: 0;
}

.card-action {
  color: var(--red);
  font-size: 24rpx;
  font-weight: 800;
}

.reminder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.reminder-row:last-child {
  border-bottom: none;
}

.reminder-label {
  color: var(--text);
  font-size: 26rpx;
  font-weight: 700;
}

.reminder-main {
  display: flex;
  flex-direction: column;
}

.reminder-status {
  margin-top: 3rpx;
  color: var(--text3);
  font-size: 21rpx;
}

.reminder-del {
  color: var(--red);
  font-size: 24rpx;
  font-weight: 800;
}

.team-cards {
  display: flex;
  gap: 16rpx;
}

.mini-team {
  flex: 1;
  min-width: 0;
  padding: 20rpx 14rpx;
  border-radius: 16rpx;
  background: #F7F9FC;
  border: 1rpx solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.mini-flag {
  width: 76rpx;
  height: 52rpx;
  margin-bottom: 12rpx;
  border-radius: 6rpx;
  background: #fff;
}

.mini-name {
  max-width: 100%;
  color: var(--text);
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}

.mini-group {
  margin-top: 4rpx;
  color: var(--text3);
  font-size: 21rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: var(--text3);
  font-size: 24rpx;
}

.info-value {
  flex: 1;
  text-align: right;
  color: var(--text);
  font-size: 25rpx;
  font-weight: 700;
}

.empty-text {
  display: block;
  color: var(--text3);
  font-size: 25rpx;
  text-align: center;
  padding: 24rpx 0;
}

.empty-tab {
  margin-top: 20rpx;
}

.lineup-note {
  margin-bottom: 18rpx;
  padding: 18rpx 22rpx;
  border-radius: 16rpx;
  background: var(--soft-gold);
  color: #6B4A00;
  font-size: 23rpx;
  line-height: 1.5;
}

.squad-columns {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.squad-card {
  flex: 1;
  min-width: 0;
  background: var(--card);
  border-radius: 18rpx;
  padding: 20rpx 16rpx;
  box-shadow: var(--shadow);
}

.squad-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid var(--border);
}

.squad-flag {
  width: 46rpx;
  height: 32rpx;
  border-radius: 5rpx;
  background: #fff;
}

.squad-title {
  flex: 1;
  color: var(--blue);
  font-size: 25rpx;
  font-weight: 900;
  line-height: 1.2;
}

.position-group {
  margin-bottom: 18rpx;
}

.position-group:last-child {
  margin-bottom: 0;
}

.position-title {
  display: block;
  margin-bottom: 8rpx;
  color: var(--text3);
  font-size: 21rpx;
  font-weight: 800;
}

.player-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #EEF2F7;
}

.player-row:last-child {
  border-bottom: none;
}

.player-number {
  width: 34rpx;
  color: var(--red);
  font-size: 22rpx;
  font-weight: 900;
}

.player-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.player-name {
  color: var(--text);
  font-size: 23rpx;
  font-weight: 800;
  line-height: 1.25;
}

.player-club {
  margin-top: 2rpx;
  color: var(--text3);
  font-size: 19rpx;
  line-height: 1.2;
}
