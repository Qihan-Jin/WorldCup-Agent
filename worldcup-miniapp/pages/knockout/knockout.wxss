.container {
  padding: 20rpx 0 70rpx;
  background: linear-gradient(180deg, #EEF4FF 0%, var(--bg) 300rpx);
  min-height: 100vh;
}

.loading {
  text-align: center;
  color: var(--text3);
  padding-top: 80rpx;
  display: block;
}

.bracket-scroll {
  width: 100%;
  white-space: nowrap;
}

.bracket-board {
  display: inline-flex;
  align-items: flex-start;
  gap: 34rpx;
  min-width: 1580rpx;
  padding: 4rpx 24rpx 28rpx;
}

.round-column {
  width: 270rpx;
  flex-shrink: 0;
}

.final-column,
.third-column {
  width: 292rpx;
}

.round-header {
  position: sticky;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 4rpx 10rpx;
  border-bottom: 4rpx solid var(--gold);
}

.round-name {
  font-size: 30rpx;
  font-weight: 800;
  color: var(--blue);
}

.round-count {
  font-size: 20rpx;
  color: var(--text3);
  font-weight: 700;
}

.round-matches {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.stage-LAST_16 .round-matches { padding-top: 50rpx; gap: 56rpx; }
.stage-QUARTER_FINALS .round-matches { padding-top: 116rpx; gap: 124rpx; }
.stage-SEMI_FINALS .round-matches { padding-top: 248rpx; gap: 260rpx; }
.stage-FINAL .round-matches { padding-top: 360rpx; }
.stage-THIRD_PLACE .round-matches { padding-top: 500rpx; }

.match-node {
  position: relative;
  display: block;
  width: 270rpx;
  box-sizing: border-box;
  padding: 16rpx;
  background: var(--card);
  border-radius: 18rpx;
  border: 1rpx solid rgba(18, 63, 134, 0.08);
  box-shadow: var(--shadow);
}

.final-node {
  border-color: rgba(246, 196, 83, 0.72);
  box-shadow: 0 18rpx 46rpx rgba(246, 196, 83, 0.18);
}
.match-node.favorite-match {
  border-color: rgba(246, 196, 83, 0.9);
}

.connector {
  position: absolute;
  top: 50%;
  right: -34rpx;
  width: 34rpx;
  height: 2rpx;
  background: rgba(18, 63, 134, 0.2);
}

.connector::after {
  content: "";
  position: absolute;
  top: -7rpx;
  right: -2rpx;
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid rgba(18, 63, 134, 0.2);
  border-right: 2rpx solid rgba(18, 63, 134, 0.2);
  transform: rotate(45deg);
}

.team-slot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  min-height: 48rpx;
  padding: 6rpx 8rpx;
  border-radius: 10rpx;
}

.team-slot.winner {
  background: var(--soft-green);
}
.team-slot.favorite {
  background: var(--soft-gold);
}

.slot-team {
  flex: 1;
  color: var(--text);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.25;
  white-space: normal;
}

.winner .slot-team {
  color: var(--green);
}
.favorite .slot-team {
  color: var(--red);
}

.slot-score {
  width: 34rpx;
  text-align: right;
  color: var(--red);
  font-size: 26rpx;
  font-weight: 800;
}

.vs-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 4rpx 0;
  color: var(--text3);
  font-size: 20rpx;
  font-weight: 800;
}

.final-node .vs-divider {
  color: var(--gold);
}

.match-info {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid var(--border);
}

.match-date {
  display: block;
  color: var(--blue);
  font-size: 21rpx;
  font-weight: 700;
}

.match-venue {
  display: block;
  margin-top: 2rpx;
  color: var(--text3);
  font-size: 19rpx;
  line-height: 1.3;
  white-space: normal;
}
